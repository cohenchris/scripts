#!/usr/bin/env bash

# Exit immediately if a command exits with a non-zero status
set -e

# Send an email
#
# send-email -e EMAIL -s SUBJECT [-f ATTACHMENT] [-r EXIT_CODE]
#   -e EMAIL      - destination email address
#   -s SUBJECT    - subject of outgoing email
#   -f ATTACHMENT - path to log file which will be sent as an attachment (optional)
#   -r EXIT_CODE  - if provided, prepends SUBJECT with "SUCCESS - " or "ERROR - " (optional)
# The email body is read from stdin
#
# Example command:
#   echo "body" | send-email -e "test@example.com" -s "Email SUBJECT" -f /path/to/attachment -r 0

# Number of times to attempt sending
MAX_MAIL_ATTEMPTS=50

# Parse arguments
while getopts "e:s:f:r:" opt; do
  case $opt in
    e) EMAIL="${OPTARG}" ;;
    s) SUBJECT="${OPTARG}" ;;
    f) ATTACHMENT="${OPTARG}" ;;
    r) RETURN_CODE="${OPTARG}" ;;
    *) echo "Usage: send-email -e EMAIL -s SUBJECT [-f ATTACHMENT] [-r EXIT_CODE]"; exit 1 ;;
  esac
done

# Prepend subject with SUCCESS/ERROR if return code is provided
if [ -n "${RETURN_CODE}" ]; then
  [ "${RETURN_CODE}" -eq 0 ] && SUBJECT="SUCCESS - ${SUBJECT}" || SUBJECT="ERROR - ${SUBJECT}"
fi

# Read in body from piped in data and write to a temp file
BODY=$(cat)
BODY_TEMPFILE=$(mktemp)
printf "%s\n" "${BODY}" > "${BODY_TEMPFILE}"

require var "${EMAIL}"
require var "${SUBJECT}"
require var "${BODY}"

# Handle optional attachment argument
if [ -n "${ATTACHMENT}" ]; then
  # attachment provided
  MUTT_CMD="mutt -s \"${SUBJECT}\" -a ${ATTACHMENT} -- ${EMAIL} < ${BODY_TEMPFILE}"
else
  # attachment not provided
  MUTT_CMD="mutt -s \"${SUBJECT}\" -- ${EMAIL} < ${BODY_TEMPFILE}"
fi

# Poll email send
while ! eval "${MUTT_CMD}"; do
  # Limit attempts. If it goes infinitely, it could fill up the disk.
  MAX_MAIL_ATTEMPTS=$((MAX_MAIL_ATTEMPTS-1))
  if [[ "${MAX_MAIL_ATTEMPTS}" -eq 0 ]]; then
    echo -e "send-email failed"
    exit 1
  fi

  sleep 5
done

# Remove body tempfile
rm "${BODY_TEMPFILE}"
